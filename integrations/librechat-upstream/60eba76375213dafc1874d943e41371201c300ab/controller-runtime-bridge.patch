@@ -178,0 +179,107 @@ async function finishResumableRequest(req, userId) {
+function getRuntimeAlwaysAppliedSkills(client) {
+  const primes = client?.options?.agent?.alwaysApplySkillPrimes;
+  if (!Array.isArray(primes)) {
+    return [];
+  }
+  return primes
+    .map((prime) => prime?.name)
+    .filter((name) => typeof name === 'string' && name.length > 0);
+}
+
+async function persistRuntimeUserTurn({
+  req,
+  client,
+  userId,
+  streamId,
+  preliminaryUserMessage,
+  preliminaryResponseMessageId,
+}) {
+  if (!preliminaryUserMessage?.messageId || !preliminaryResponseMessageId) {
+    throw new Error('Runtime routing requires preallocated user and assistant message IDs');
+  }
+  const userMessage = {
+    ...preliminaryUserMessage,
+    sender: 'User',
+    isCreatedByUser: true,
+  };
+
+  if (req.body.files) {
+    if (!Array.isArray(client?.options?.attachments)) {
+      throw new Error('Runtime routing requires initialized LibreChat file attachments');
+    }
+    const files = buildMessageFiles(req.body.files, client.options.attachments);
+    if (files.length !== req.body.files.length) {
+      throw new Error('Runtime routing could not resolve every uploaded file attachment');
+    }
+    userMessage.files = files;
+    delete userMessage.image_urls;
+  }
+
+  if (!Array.isArray(userMessage.alwaysAppliedSkills)) {
+    const alwaysAppliedSkills = getRuntimeAlwaysAppliedSkills(client);
+    if (alwaysAppliedSkills.length > 0) {
+      userMessage.alwaysAppliedSkills = alwaysAppliedSkills;
+    }
+  }
+
+  const saved = await client.saveMessageToDatabase(
+    userMessage,
+    client.getSaveOptions(),
+    userId,
+  );
+  if (!saved?.message || !saved?.conversation) {
+    throw new Error('Runtime routing did not durably save the user message and conversation');
+  }
+  client.savedMessageIds?.add(userMessage.messageId);
+
+  await GenerationJobManager.updateMetadata(streamId, {
+    responseMessageId: preliminaryResponseMessageId,
+    userMessage,
+  });
+  await GenerationJobManager.emitChunk(streamId, {
+    created: true,
+    message: userMessage,
+    streamId,
+  });
+  return { userMessage: saved.message, conversation: saved.conversation };
+}
+
+async function saveRuntimeHandoffFailure({
+  req,
+  userId,
+  conversationId,
+  endpoint,
+  iconURL,
+  model,
+  sender,
+  userMessageId,
+  assistantMessageId,
+}) {
+  if (!userMessageId || !assistantMessageId) {
+    return;
+  }
+  await saveMessage(
+    {
+      userId,
+      isTemporary: req?.body?.isTemporary,
+      interfaceConfig: req?.config?.interfaceConfig,
+    },
+    {
+      messageId: assistantMessageId,
+      conversationId,
+      parentMessageId: userMessageId,
+      sender: sender ?? 'AI',
+      text: '文件任务启动失败，请稍后重试。',
+      unfinished: false,
+      error: true,
+      isCreatedByUser: false,
+      user: userId,
+      endpoint,
+      iconURL,
+      model,
+      ...(req.body?.agent_id && { agent_id: req.body.agent_id }),
+    },
+    { context: 'api/server/controllers/agents/request.js - Runtime handoff failure' },
+  );
+}
+
